---
const team = [
  {
    name: "Dev Nandan Anoop",
    role: "Founder",
    bio: "Dev is a postgraduate in math and data science wanting to use his skills to build AI systems which act as a natural extension of the human race."
  },
  {
    name: "Visakh Abhayan",
    role: "Founding Engineer",
    bio: "Visakh was a crucial part in implementing Beckn protocol to build a platform that accelerates industry expertise among college students."
  },
  {
    name: "Aditya Manoj",
    role: "Head Of Design",
    bio: "Aditya believes good design is the key to every great product in the market. He carries forward this passion to build our product and make it as intuitive as possible."
  }
];
---

<section id="team" class="team-section">
  <div class="container section-container">
    <div class="header-wrapper">
      <h2 class="section-title">Meet The Team</h2>
      <p class="section-subtitle">
        A small team of three innovators combining creativity, technology, and strategy to build impactful solutions.
      </p>
    </div>

    <div class="team-grid">
      {team.map((member) => (
        <div class="team-card">
          <div class="team-image-placeholder"></div>
          <div class="team-info">
            <h3 class="team-name">{member.name}</h3>
            <p class="team-role">{member.role}</p>
            <p class="team-bio">{member.bio}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .team-section {
    padding: 100px 0;
  }

  .section-container {
    padding: 0 40px;
    max-width: 1280px;
  }

  .header-wrapper {
    border-top: 1px solid #929292;
    padding-top: 80px;
    margin-bottom: 80px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .section-title {
    font-size: 60px;
    color: var(--c-black);
    margin-bottom: 40px;
  }

  .section-subtitle {
    font-size: 16px;
    line-height: 22px;
    color: var(--c-text-muted);
    max-width: 720px;
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 130px; /* To account for space between 302px cards in 1174px frame */
    justify-content: center;
  }

  .team-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    text-align: center;
  }

  .team-image-placeholder {
    width: 302px;
    height: 292px;
    border: 4px solid var(--c-border-hero);
    border-radius: 30px;
    background-color: transparent;
    transition: transform 0.3s ease, border-color 0.3s ease;
  }

  .team-card:hover .team-image-placeholder {
    transform: scale(1.02);
    border-color: var(--c-primary);
  }

  .team-info {
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-items: center;
  }

  .team-name {
    font-family: var(--font-sans);
    font-size: 20px;
    font-weight: 500;
    color: var(--c-black);
    line-height: 28px;
    margin: 0;
  }

  .team-role {
    font-size: 14px;
    font-weight: 500;
    color: var(--c-black);
    line-height: 17px;
    margin-bottom: 8px; /* Slight extra gap before bio */
  }

  .team-bio {
    font-size: 15px;
    line-height: 21px;
    color: var(--c-text-muted);
  }

  @media (max-width: 1024px) {
    .team-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 60px;
    }
  }

  @media (max-width: 768px) {
    .section-title {
      font-size: 48px;
    }
    .team-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .team-image-placeholder {
      width: 100%;
      max-width: 302px;
    }
  }
</style>
