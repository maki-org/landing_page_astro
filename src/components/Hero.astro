<section class="hero-section" id="hero-sequence">
  <!-- Pinned sequence background -->
  <div class="canvas-container">
    <canvas id="hero-lightpass"></canvas>
  </div>

  <div class="scroll-texts-container">
    <div class="scroll-text" id="scroll-text-1">
      <h3 class="scroll-heading">The Classroom just got Smarter !</h3>
      <p class="scroll-sub">Scroll to see how.</p>
    </div>
    <div class="side-text left-side" id="scroll-text-2">
      <h3 class="side-heading">Its listening</h3>
    </div>
    <div class="side-text right-side" id="scroll-text-3">
      <h3 class="side-heading">
        Every lecture.<br />Every word.<br />Every detail.
      </h3>
    </div>
    <div class="side-text left-side" id="scroll-text-4">
      <h3 class="side-heading">Meet Wy</h3>
    </div>
    <div class="side-text right-side" id="scroll-text-4-sub">
      <p
        class="side-sub"
        style="font-weight: 700; color: var(--c-black); font-size: 24px;"
      >
        The intelligent infrastructure for modern classrooms.<br />All packed
        into one device.
      </p>
    </div>
    <div class="scroll-text" id="scroll-text-5">
      <h3 class="scroll-heading">One room. Infinite retention.</h3>
    </div>
  </div>

  <div class="container hero-container-inner">
    <hr class="hero-divider" />

    <div class="hero-content">
      <h1 class="hero-title">Introducing Wy.</h1>
      <h2 class="hero-subtitle">Building Intelligent Infra for Classrooms.</h2>
      <!-- <p class="hero-description">
        Our system listens in real-world classrooms, processes live lectures and
        transforms audio into academic intelligence.
      </p> -->

      <div class="hero-actions flex justify-center gap-24">
        <a href="#request" class="btn-primary">Request Early Access</a>
        <a href="#demo" class="btn-outline">Watch A Demo</a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-section {
    position: relative;
    width: 100%;
    height: 100vh; /* absolute max viewport height */
    overflow: hidden;
    background-color: var(--c-white);
  }

  .canvas-container {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1; /* behind content */
    display: flex;
    justify-content: center;
    align-items: center;
  }

  #hero-lightpass {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .scroll-texts-container {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 5;
    pointer-events: none;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .scroll-text {
    position: absolute;
    text-align: center;
    opacity: 0;
    visibility: hidden; /* Prevent flash before GSAP init */
    transform: translateY(20px);
    width: 100%;
    padding: 0 20px;
  }

  .scroll-heading {
    font-size: 64px;
    font-family: var(--font-serif);
    color: var(--c-black);
    line-height: 1.1;
    margin-bottom: 12px;
  }

  .scroll-sub {
    font-size: 24px;
    font-family: var(--font-sans);
    color: var(--c-text-muted);
  }

  .side-text {
    position: absolute;
    top: 50%;
    margin-top: -50px;
    opacity: 0;
    visibility: hidden; /* Prevent flash before GSAP init */
    transform: translateY(20px);
    width: 350px;
  }

  .left-side {
    left: 8%;
    text-align: left;
  }

  .right-side {
    right: 8%;
    text-align: left;
  }

  #scroll-text-5 {
    margin-top: 220px;
  }

  .side-heading {
    font-size: 42px;
    font-family: var(--font-serif);
    color: var(--c-black);
    line-height: 1.2;
    margin-bottom: 12px;
  }

  .side-sub {
    font-size: 20px;
    font-family: var(--font-sans);
    color: var(--c-text-muted);
    line-height: 1.4;
  }

  .hero-container-inner {
    position: relative;
    z-index: 10; /* above canvas */
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    padding: 0 40px;
    padding-top: 60px; /* navbar offset */
    pointer-events: none; /* Let pointer events pass to canvas if needed */
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    pointer-events: auto; /* Re-enable clicks */
    opacity: 0;
    visibility: hidden; /* Prevent flash before GSAP init */
    transform: translateY(50px);
  }

  .hero-divider {
    width: 100%;
    max-width: 1200px;
    height: 1px;
    background-color: var(--c-black);
    border: none;
    margin: 0 auto;
    position: absolute;
    top: 95px;
  }

  .hero-title {
    font-size: 160px;
    line-height: 1.1;
    color: var(--c-black);
    margin-bottom: 20px;
    letter-spacing: -0.02em;
  }

  .hero-subtitle {
    font-family: var(--font-sans);
    color: var(--c-primary);
    font-size: 24px;
    font-weight: 700;
    line-height: 1.4;
    margin-bottom: 28px;
  }

  .hero-description {
    font-size: 20px;
    color: var(--c-black);
    max-width: 720px;
    margin: 0 auto 50px;
    line-height: 1.4;
  }

  .hero-actions .btn-primary {
    padding: 14px 22px;
    min-width: 185px;
    justify-content: center;
  }

  .hero-actions .btn-outline {
    min-width: 142px;
  }

  @media (max-width: 1024px) {
    .hero-title {
      font-size: 100px;
    }
    .scroll-heading {
      font-size: 48px;
    }
  }

  @media (max-width: 768px) {
    .hero-title {
      font-size: 50px;
    }
    .hero-subtitle {
      font-size: 20px;
    }
    .hero-description {
      font-size: 16px;
    }
    .hero-actions {
      flex-direction: column;
      gap: 16px;
      width: 100%;
    }
    .hero-actions a {
      width: 100%;
    }
    .scroll-heading,
    .side-heading {
      font-size: 32px;
      text-shadow:
        0 0 20px rgba(255, 255, 255, 1),
        0 0 10px rgba(255, 255, 255, 0.8);
      color: var(--c-black);
    }
    .scroll-sub,
    .side-sub {
      font-size: 18px;
      text-shadow:
        0 0 20px rgba(255, 255, 255, 1),
        0 0 10px rgba(255, 255, 255, 0.8);
      color: var(--c-black);
    }
    .scroll-text,
    .side-text {
      width: 100%;
      left: 0 !important;
      right: 0 !important;
      text-align: center !important;
      padding: 0 20px;
      top: auto;
      bottom: 15%;
      margin-top: 0;
    }
    #scroll-text-4 {
      top: 15% !important;
      bottom: auto !important;
    }
    #scroll-text-4-sub {
      bottom: 12% !important;
    }
    .hero-container-inner {
      padding: 0 20px;
      padding-top: 60px;
    }
  }
</style>

  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  // Normalize scroll to fix jumpy iOS Safari UI bar behaviors
  ScrollTrigger.normalizeScroll(true);

  // Fix iOS Safari/Chrome: prevent ScrollTrigger from recalculating on toolbar resize
  ScrollTrigger.config({
    ignoreMobileResize: true,
  });

  // Force-hide all overlay elements immediately before ScrollTrigger initializes
  // This prevents the flash of all texts showing on load/reload
  gsap.set(
    [
      "#scroll-text-1",
      "#scroll-text-2",
      "#scroll-text-3",
      "#scroll-text-4",
      "#scroll-text-4-sub",
      "#scroll-text-5",
      ".hero-content",
    ],
    { autoAlpha: 0, y: 20 },
  );

  // Scroll to top on page load to prevent browser restoring mid-scroll position
  if ("scrollRestoration" in history) {
    history.scrollRestoration = "manual";
  }
  window.scrollTo(0, 0);

  function getViewportSize() {
    const hero = document.querySelector(".hero-section");
    return {
      width: hero ? hero.clientWidth : window.innerWidth,
      height: hero ? hero.clientHeight : window.innerHeight,
    };
  }

  function initHeroAnimation(frameCount: number, frameDir: string) {
    const canvas = document.getElementById(
      "hero-lightpass",
    ) as HTMLCanvasElement;
    let resizeCanvas: () => void;

    if (!canvas) return () => {};
    const context = canvas.getContext("2d");

    const currentFrame = (index: number) => {
      return `/${frameDir}/ezgif-frame-${(index + 1).toString().padStart(3, "0")}.jpg`;
    };

    const images: HTMLImageElement[] = [];
    const sequence = { frame: 0 };

    for (let i = 0; i < frameCount; i++) {
      const img = new Image();
      img.src = currentFrame(i);
      images.push(img);
    }

    resizeCanvas = () => {
      const vp = getViewportSize();
      canvas.width = vp.width;
      canvas.height = vp.height;
      render();
    };

    images[0].onload = () => {
      resizeCanvas();
      window.addEventListener("resize", resizeCanvas);
    };

    function render() {
      if (images[sequence.frame] && context) {
        const img = images[sequence.frame];
        const canvasRatio = canvas.width / canvas.height;
        const imgRatio = img.width / img.height;

        let drawWidth, drawHeight, offsetX, offsetY;

        if (canvasRatio > imgRatio) {
          drawWidth = canvas.width;
          drawHeight = canvas.width / imgRatio;
        } else {
          drawWidth = canvas.height * imgRatio;
          drawHeight = canvas.height;
        }

        offsetX = (canvas.width - drawWidth) / 2;
        offsetY = (canvas.height - drawHeight) / 2;

        context.clearRect(0, 0, canvas.width, canvas.height);
        context.drawImage(img, offsetX, offsetY, drawWidth, drawHeight);
      }
    }

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: "#hero-sequence",
        start: "top top",
        end: "+=8000",
        scrub: 1,
        pin: true,
      },
    });

    tl.to(
      sequence,
      {
        frame: frameCount - 1,
        snap: "frame",
        ease: "none",
        onUpdate: () => render(),
        duration: 4,
      },
      0,
    );
    tl.to("#scroll-text-1", { autoAlpha: 1, y: 0, duration: 0.5 }, 0);
    tl.to("#scroll-text-1", { autoAlpha: 0, y: -20, duration: 0.5 }, 1.0);
    tl.to("#scroll-text-2", { autoAlpha: 1, y: 0, duration: 0.5 }, 1.5);
    tl.to("#scroll-text-2", { autoAlpha: 0, y: -20, duration: 0.5 }, 2.5);
    tl.to("#scroll-text-3", { autoAlpha: 1, y: 0, duration: 0.5 }, 3.0);
    tl.to("#scroll-text-3", { autoAlpha: 0, y: -20, duration: 0.5 }, 4.0);
    tl.to(sequence, { frame: frameCount - 1, duration: 0.5 }, 4);
    tl.to("#scroll-text-4", { autoAlpha: 1, y: 0, duration: 0.5 }, 4.5);
    tl.to("#scroll-text-4-sub", { autoAlpha: 1, y: 0, duration: 0.5 }, 4.5);
    tl.to("#scroll-text-4", { autoAlpha: 0, y: -20, duration: 0.5 }, 5.5);
    tl.to("#scroll-text-4-sub", { autoAlpha: 0, y: -20, duration: 0.5 }, 5.5);
    tl.to(
      sequence,
      {
        frame: 0,
        snap: "frame",
        ease: "none",
        onUpdate: () => render(),
        duration: 4,
      },
      4.5,
    );
    tl.to("#scroll-text-5", { autoAlpha: 1, y: 0, duration: 0.5 }, 6.5);
    tl.to("#scroll-text-5", { autoAlpha: 0, y: -20, duration: 0.5 }, 7.5);
    tl.to(
      ".hero-content",
      { autoAlpha: 1, y: 0, ease: "power2.out", duration: 1 },
      8.0,
    );

    return () => {
      if (resizeCanvas) {
        window.removeEventListener("resize", resizeCanvas);
      }
      tl.kill();
    };
  }

  let mm = gsap.matchMedia();

  mm.add("(min-width: 769px)", () => {
    return initHeroAnimation(265, "desktop_frames");
  });
  mm.add("(max-width: 768px)", () => {
    return initHeroAnimation(300, "mobile_frames");
  });
</script>
