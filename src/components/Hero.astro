---
---

<section class="hero-section" id="hero-sequence">
  <!-- Pinned sequence background -->
  <div class="canvas-container">
    <canvas id="hero-lightpass"></canvas>
  </div>

  <div class="scroll-texts-container">
    <div class="scroll-text" id="scroll-text-1">
      <h3 class="scroll-heading">The Classroom just got Smarter !</h3>
      <p class="scroll-sub">Scroll to see how.</p>
    </div>
    <div class="scroll-text" id="scroll-text-2">
      <h3 class="scroll-heading">Its listening</h3>
    </div>
    <div class="scroll-text" id="scroll-text-3">
      <h3 class="scroll-heading">Every lecture. Every word. Every detail.</h3>
    </div>
    <div class="scroll-text" id="scroll-text-4">
      <h3 class="scroll-heading">Meet Wy. The intelligent infrastructure for modern classrooms<br/>All packed into one device</h3>
    </div>
    <div class="scroll-text" id="scroll-text-5">
      <h3 class="scroll-heading">One room. Infinite retention.</h3>
    </div>
  </div>

  <div class="container hero-container-inner">
    <hr class="hero-divider" />
    
    <div class="hero-content">
      <h1 class="hero-title">Introducing maki.</h1>
      <h2 class="hero-subtitle">Building Intelligent Infra for Classrooms.</h2>
      <p class="hero-description">
        Our system listens in real-world classrooms, processes live lectures and transforms audio into academic intelligence.
      </p>

      <div class="hero-actions flex justify-center gap-24">
        <a href="#request" class="btn-primary">Request Early Access</a>
        <a href="#demo" class="btn-outline">Watch A Demo</a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-section {
    position: relative;
    width: 100%;
    height: 100vh;
    overflow: hidden;
    background-color: var(--c-white);
  }

  .canvas-container {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1; /* behind content */
    display: flex;
    justify-content: center;
    align-items: center;
  }

  #hero-lightpass {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .scroll-texts-container {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    z-index: 5;
    pointer-events: none;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .scroll-text {
    position: absolute;
    text-align: center;
    opacity: 0; /* Hidden by default */
    transform: translateY(20px);
    width: 100%;
    padding: 0 20px;
  }

  .scroll-heading {
    font-size: 64px;
    font-family: var(--font-serif);
    color: var(--c-black);
    line-height: 1.1;
    margin-bottom: 12px;
  }

  .scroll-sub {
    font-size: 24px;
    font-family: var(--font-sans);
    color: var(--c-black);
  }

  .hero-container-inner {
    position: relative;
    z-index: 10; /* above canvas */
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    padding: 0 40px;
    padding-top: 60px; /* navbar offset */
    pointer-events: none; /* Let pointer events pass to canvas if needed */
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    pointer-events: auto; /* Re-enable clicks */
    opacity: 0; /* Hidden initially, controlled by GSAP */
    transform: translateY(50px);
  }

  .hero-divider {
    width: 100%;
    max-width: 1200px;
    height: 1px;
    background-color: var(--c-black);
    border: none;
    margin: 0 auto;
    position: absolute;
    top: 95px;
  }

  .hero-title {
    font-size: 160px;
    line-height: 1.1; 
    color: var(--c-black);
    margin-bottom: 20px;
    letter-spacing: -0.02em;
  }

  .hero-subtitle {
    font-family: var(--font-sans);
    color: var(--c-primary);
    font-size: 24px;
    font-weight: 700;
    line-height: 1.4;
    margin-bottom: 28px;
  }

  .hero-description {
    font-size: 20px;
    color: var(--c-text-muted);
    max-width: 720px;
    margin: 0 auto 50px;
    line-height: 1.4;
  }

  .hero-actions .btn-primary {
    padding: 14px 22px;
    min-width: 185px;
    justify-content: center;
  }

  .hero-actions .btn-outline {
    min-width: 142px;
  }

  @media (max-width: 1024px) {
    .hero-title {
      font-size: 100px;
    }
    .scroll-heading {
      font-size: 48px;
    }
  }

  @media (max-width: 768px) {
    .hero-title {
      font-size: 60px;
    }
    .hero-subtitle {
      font-size: 20px;
    }
    .hero-description {
      font-size: 16px;
    }
    .hero-actions {
      flex-direction: column;
      gap: 16px;
    }
    .scroll-heading {
      font-size: 36px;
    }
    .scroll-sub {
      font-size: 18px;
    }
  }
</style>

  <script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';

    gsap.registerPlugin(ScrollTrigger);

    const canvas = document.getElementById("hero-lightpass") as HTMLCanvasElement;
    
    if (canvas) {
      const context = canvas.getContext("2d");
      
      const frameCount = 240;
      const currentFrame = (index: number) => {
        return `/frames/ezgif-frame-${(index + 1).toString().padStart(3, '0')}.jpg`;
      };

      const images: HTMLImageElement[] = [];
      const sequence = { frame: 0 }; // Start at the FIRST frame

      // Preload images
      for (let i = 0; i < frameCount; i++) {
          const img = new Image();
          img.src = currentFrame(i);
          images.push(img);
      }

      images[0].onload = () => {
        resizeCanvas();
        window.addEventListener('resize', resizeCanvas);
      };

      function resizeCanvas() {
        // Make canvas size internal match viewport size
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
        render();
      }

      function render() {
        if (images[sequence.frame] && context) {
          const img = images[sequence.frame];
          const canvasRatio = canvas.width / canvas.height;
          const imgRatio = img.width / img.height;

          let drawWidth, drawHeight, offsetX, offsetY;

          // Cover logic to fill screen
          if (canvasRatio > imgRatio) {
            drawWidth = canvas.width;
            drawHeight = canvas.width / imgRatio;
            offsetX = 0;
            offsetY = (canvas.height - drawHeight) / 2;
          } else {
            drawWidth = canvas.height * imgRatio;
            drawHeight = canvas.height;
            offsetX = (canvas.width - drawWidth) / 2;
            offsetY = 0;
          }

          context.clearRect(0, 0, canvas.width, canvas.height);
          context.drawImage(img, offsetX, offsetY, drawWidth, drawHeight);
        }
      }

      // Master Timeline for ScrollTrigger
      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: "#hero-sequence",
          start: "top top",
          end: "+=8000", // A very tall virtual scroll space to fit everything seamlessly
          scrub: 1, // Smoothing out the scrub so text feels more elegant
          pin: true,
        }
      });

      // We structure the timeline using relative temporal positions (0 to 10 conceptually).
      // Total duration of canvas forward is 4 units
      tl.to(sequence, {
        frame: frameCount - 1,
        snap: "frame",
        ease: "none",
        onUpdate: () => render(),
        duration: 4
      }, 0);

      // Text 1 appears immediately, fades out
      tl.to("#scroll-text-1", { opacity: 1, y: 0, duration: 0.5 }, 0);
      tl.to("#scroll-text-1", { opacity: 0, y: -20, duration: 0.5 }, 1.0);

      // Text 2
      tl.to("#scroll-text-2", { opacity: 1, y: 0, duration: 0.5 }, 1.5);
      tl.to("#scroll-text-2", { opacity: 0, y: -20, duration: 0.5 }, 2.5);

      // Text 3
      tl.to("#scroll-text-3", { opacity: 1, y: 0, duration: 0.5 }, 3.0);
      tl.to("#scroll-text-3", { opacity: 0, y: -20, duration: 0.5 }, 4.0);

      // Pause image briefly before going backward
      tl.to(sequence, { frame: frameCount - 1, duration: 0.5 }, 4);

      // Text 4 during the hold
      tl.to("#scroll-text-4", { opacity: 1, y: 0, duration: 0.5 }, 4.5);
      tl.to("#scroll-text-4", { opacity: 0, y: -20, duration: 0.5 }, 5.5);

      // Canvas backwards
      tl.to(sequence, {
        frame: 0,
        snap: "frame",
        ease: "none",
        onUpdate: () => render(),
        duration: 4 // duration 4 -> from time 4.5 to 8.5
      }, 4.5);

      // Text 5 fades in slightly after the reversal begins
      tl.to("#scroll-text-5", { opacity: 1, y: 0, duration: 0.5 }, 6.5);
      tl.to("#scroll-text-5", { opacity: 0, y: -20, duration: 0.5 }, 7.5);

      // Finally fade in the main hero content at the very end
      tl.to(".hero-content", {
        opacity: 1,
        y: 0,
        ease: "power2.out",
        duration: 1
      }, 8.0);
    }
  </script>
