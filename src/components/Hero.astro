---
---

<section class="hero-section" id="hero-sequence">
  <!-- Pinned sequence background -->
  <div class="canvas-container">
    <canvas id="hero-lightpass"></canvas>
  </div>

  <div class="container hero-container-inner">
    <hr class="hero-divider" />
    
    <div class="hero-content">
      <h1 class="hero-title">Introducing maki.</h1>
      <h2 class="hero-subtitle">Building Intelligent Infra for Classrooms.</h2>
      <p class="hero-description">
        Our system listens in real-world classrooms, processes live lectures and transforms audio into academic intelligence.
      </p>

      <div class="hero-actions flex justify-center gap-24">
        <a href="#request" class="btn-primary">Request Early Access</a>
        <a href="#demo" class="btn-outline">Watch A Demo</a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-section {
    position: relative;
    width: 100%;
    height: 100vh;
    overflow: hidden;
    background-color: var(--c-white);
  }

  .canvas-container {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1; /* behind content */
    display: flex;
    justify-content: center;
    align-items: center;
  }

  #hero-lightpass {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hero-container-inner {
    position: relative;
    z-index: 10; /* above canvas */
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    padding: 0 40px;
    padding-top: 60px; /* navbar offset */
    pointer-events: none; /* Let pointer events pass to canvas if needed */
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    pointer-events: auto; /* Re-enable clicks */
  }

  .hero-divider {
    width: 100%;
    max-width: 1200px;
    height: 1px;
    background-color: var(--c-black);
    border: none;
    margin: 0 auto;
    position: absolute;
    top: 95px;
  }

  .hero-title {
    font-size: 160px;
    line-height: 1.1; 
    color: var(--c-black);
    margin-bottom: 20px;
    letter-spacing: -0.02em;
    animation: fadeUp 0.8s ease-out forwards;
    transform: translateY(20px);
    opacity: 0;
  }

  .hero-subtitle {
    font-family: var(--font-sans);
    color: var(--c-primary);
    font-size: 24px;
    font-weight: 700;
    line-height: 1.4;
    margin-bottom: 28px;
    animation: fadeUp 0.8s ease-out 0.2s forwards;
    transform: translateY(20px);
    opacity: 0;
  }

  .hero-description {
    font-size: 20px;
    color: var(--c-text-muted);
    max-width: 720px;
    margin: 0 auto 50px;
    line-height: 1.4;
    animation: fadeUp 0.8s ease-out 0.4s forwards;
    transform: translateY(20px);
    opacity: 0;
  }

  .hero-actions {
    animation: fadeUp 0.8s ease-out 0.6s forwards;
    transform: translateY(20px);
    opacity: 0;
  }

  .hero-actions .btn-primary {
    padding: 14px 22px;
    min-width: 185px;
    justify-content: center;
  }

  .hero-actions .btn-outline {
    min-width: 142px;
  }

  @keyframes fadeUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 1024px) {
    .hero-title {
      font-size: 100px;
    }
  }

  @media (max-width: 768px) {
    .hero-title {
      font-size: 60px;
    }
    .hero-subtitle {
      font-size: 20px;
    }
    .hero-description {
      font-size: 16px;
    }
    .hero-actions {
      flex-direction: column;
      gap: 16px;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const canvas = document.getElementById("hero-lightpass") as HTMLCanvasElement;
  
  if (canvas) {
    const context = canvas.getContext("2d");
    
    const frameCount = 240;
    const currentFrame = (index: number) => {
      return `/frames/ezgif-frame-${(index + 1).toString().padStart(3, '0')}.jpg`;
    };

    const images: HTMLImageElement[] = [];
    const sequence = { frame: 0 };

    // Preload images
    for (let i = 0; i < frameCount; i++) {
        const img = new Image();
        img.src = currentFrame(i);
        images.push(img);
    }

    images[0].onload = () => {
      resizeCanvas();
      window.addEventListener('resize', resizeCanvas);
    };

    function resizeCanvas() {
      // Make canvas size internal match viewport size
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
      render();
    }

    function render() {
      if (images[sequence.frame] && context) {
        const img = images[sequence.frame];
        const canvasRatio = canvas.width / canvas.height;
        const imgRatio = img.width / img.height;

        let drawWidth, drawHeight, offsetX, offsetY;

        // Cover logic to fill screen
        if (canvasRatio > imgRatio) {
          drawWidth = canvas.width;
          drawHeight = canvas.width / imgRatio;
          offsetX = 0;
          offsetY = (canvas.height - drawHeight) / 2;
        } else {
          drawWidth = canvas.height * imgRatio;
          drawHeight = canvas.height;
          offsetX = (canvas.width - drawWidth) / 2;
          offsetY = 0;
        }

        context.clearRect(0, 0, canvas.width, canvas.height);
        context.drawImage(img, offsetX, offsetY, drawWidth, drawHeight);
      }
    }

    // Scroll trigger to scrub through frames while pinning the hero section
    gsap.to(sequence, {
      frame: frameCount - 1,
      snap: "frame",
      ease: "none",
      scrollTrigger: {
        trigger: "#hero-sequence",
        start: "top top",
        end: "+=2500", // The hero will stay pinned for 2500px of virtual scrolling
        scrub: 0.5,
        pin: true,
      },
      onUpdate: () => render() 
    });

    // Fade out hero text slightly as the sequence scrubs down so the device stands out
    gsap.to(".hero-content", {
      opacity: 0,
      y: -50,
      scrollTrigger: {
        trigger: "#hero-sequence",
        start: "top top",
        end: "+=1500", // Fades out completely after 1500px
        scrub: true
      }
    });
  }
</script>
