---
---

<section class="hero-section">
  <div class="container hero-container">
    <hr class="hero-divider" />
    
    <h1 class="hero-title">Introducing maki.</h1>
    <h2 class="hero-subtitle">Building Intelligent Infra for Classrooms.</h2>
    <p class="hero-description">
      Our system listens in real-world classrooms, processes live lectures and transforms audio into academic intelligence.
    </p>

    <div class="hero-actions flex justify-center gap-24">
      <a href="#request" class="btn-primary">Request Early Access</a>
      <a href="#demo" class="btn-outline">Watch A Demo</a>
    </div>

    <div class="hero-image-wrapper">
      <img src="/images/whatsapp_image_2026-02-10_at_17.45.57_1.png" alt="Maki App Dashboard" class="hero-image" />
    </div>
  </div>
</section>

<style>
  .hero-section {
    padding-top: 95px; /* Offset from top */
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .hero-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0 40px;
  }

  .hero-divider {
    width: 100%;
    max-width: 1200px;
    height: 1px;
    background-color: var(--c-black);
    border: none;
    margin: 0 auto;
  }

  .hero-title {
    font-size: 160px;
    line-height: 1.1; /* slightly tighter than 136px / 160px ratio */
    color: var(--c-black);
    margin-top: 50px;
    margin-bottom: 20px;
    letter-spacing: -0.02em;
    animation: fadeUp 0.8s ease-out forwards;
    transform: translateY(20px);
    opacity: 0;
  }

  .hero-subtitle {
    font-family: var(--font-sans);
    color: var(--c-primary);
    font-size: 24px;
    font-weight: 700;
    line-height: 1.4;
    margin-bottom: 28px;
    animation: fadeUp 0.8s ease-out 0.2s forwards;
    transform: translateY(20px);
    opacity: 0;
  }

  .hero-description {
    font-size: 20px;
    color: var(--c-text-muted);
    max-width: 720px;
    margin: 0 auto 50px;
    line-height: 1.4;
    animation: fadeUp 0.8s ease-out 0.4s forwards;
    transform: translateY(20px);
    opacity: 0;
  }

  .hero-actions {
    margin-bottom: 100px;
    animation: fadeUp 0.8s ease-out 0.6s forwards;
    transform: translateY(20px);
    opacity: 0;
  }

  .hero-actions .btn-primary {
    padding: 14px 22px;
    min-width: 185px;
    justify-content: center;
  }

  .hero-actions .btn-outline {
    min-width: 142px;
  }

  .hero-image-wrapper {
    width: 100%;
    max-width: 1145px;
    margin: 0 auto;
    border-radius: 20px;
    box-shadow: 0px 4px 8px 0px rgba(72, 92, 17, 0.25);
    overflow: hidden;
    animation: fadeUp 1s ease-out 0.8s forwards;
    transform: translateY(40px);
    opacity: 0;
  }

  .hero-image {
    width: 100%;
    height: auto;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .hero-image-wrapper:hover .hero-image {
    transform: scale(1.02);
  }

  @keyframes fadeUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 1024px) {
    .hero-title {
      font-size: 100px;
    }
    .hero-section {
      padding-top: 120px;
    }
  }

  @media (max-width: 768px) {
    .hero-title {
      font-size: 60px;
      margin-top: 40px;
    }
    .hero-subtitle {
      font-size: 20px;
    }
    .hero-description {
      font-size: 16px;
    }
    .hero-actions {
      flex-direction: column;
      gap: 16px;
    }
  }
</style>
