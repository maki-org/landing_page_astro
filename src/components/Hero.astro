---
---

<section class="hero-section" id="hero-container">
  <div class="container hero-container-inner">
    <hr class="hero-divider" />
    
    <h1 class="hero-title">Introducing maki.</h1>
    <h2 class="hero-subtitle">Building Intelligent Infra for Classrooms.</h2>
    <p class="hero-description">
      Our system listens in real-world classrooms, processes live lectures and transforms audio into academic intelligence.
    </p>

    <div class="hero-actions flex justify-center gap-24">
      <a href="#request" class="btn-primary">Request Early Access</a>
      <a href="#demo" class="btn-outline">Watch A Demo</a>
    </div>

    <!-- Pinned sequence container -->
    <div class="hero-image-wrapper" id="hero-image-container">
      <canvas id="hero-lightpass"></canvas>
    </div>
  </div>
</section>

<style>
  .hero-section {
    padding-top: 95px; /* Offset from top */
    text-align: center;
    position: relative;
    /* We add extra height here so the user has room to scroll and trigger the animation 
       without instantly scrolling past the hero. GSAP will scrub based on this. */
    min-height: 200vh;
  }

  .hero-container-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0 40px;
  }

  .hero-divider {
    width: 100%;
    max-width: 1200px;
    height: 1px;
    background-color: var(--c-black);
    border: none;
    margin: 0 auto;
  }

  .hero-title {
    font-size: 160px;
    line-height: 1.1; 
    color: var(--c-black);
    margin-top: 50px;
    margin-bottom: 20px;
    letter-spacing: -0.02em;
    animation: fadeUp 0.8s ease-out forwards;
    transform: translateY(20px);
    opacity: 0;
  }

  .hero-subtitle {
    font-family: var(--font-sans);
    color: var(--c-primary);
    font-size: 24px;
    font-weight: 700;
    line-height: 1.4;
    margin-bottom: 28px;
    animation: fadeUp 0.8s ease-out 0.2s forwards;
    transform: translateY(20px);
    opacity: 0;
  }

  .hero-description {
    font-size: 20px;
    color: var(--c-text-muted);
    max-width: 720px;
    margin: 0 auto 50px;
    line-height: 1.4;
    animation: fadeUp 0.8s ease-out 0.4s forwards;
    transform: translateY(20px);
    opacity: 0;
  }

  .hero-actions {
    margin-bottom: 60px;
    animation: fadeUp 0.8s ease-out 0.6s forwards;
    transform: translateY(20px);
    opacity: 0;
  }

  .hero-actions .btn-primary {
    padding: 14px 22px;
    min-width: 185px;
    justify-content: center;
  }

  .hero-actions .btn-outline {
    min-width: 142px;
  }

  .hero-image-wrapper {
    width: 100%;
    max-width: 1145px;
    margin: 0 auto;
    border-radius: 20px;
    box-shadow: 0px 4px 8px 0px rgba(72, 92, 17, 0.25);
    overflow: hidden;
    background: var(--c-black);
    /* For canvas sizing */
    display: flex;
    justify-content: center;
    align-items: center;
    opacity: 0;
    transform: translateY(40px);
    animation: fadeUp 1s ease-out 0.8s forwards;
  }

  #hero-lightpass {
    width: 100%;
    max-height: 70vh;
    object-fit: cover;
    display: block;
  }

  @keyframes fadeUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 1024px) {
    .hero-title {
      font-size: 100px;
    }
    .hero-section {
      padding-top: 120px;
      min-height: 150vh;
    }
  }

  @media (max-width: 768px) {
    .hero-title {
      font-size: 60px;
      margin-top: 40px;
    }
    .hero-subtitle {
      font-size: 20px;
    }
    .hero-description {
      font-size: 16px;
    }
    .hero-actions {
      flex-direction: column;
      gap: 16px;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const canvas = document.getElementById("hero-lightpass") as HTMLCanvasElement;
  
  if (canvas) {
    const context = canvas.getContext("2d");
    
    const frameCount = 240;
    const currentFrame = (index: number) => {
      return `/frames/ezgif-frame-${(index + 1).toString().padStart(3, '0')}.jpg`;
    };

    const images: HTMLImageElement[] = [];
    const sequence = { frame: 0 };

    // Preload images
    for (let i = 0; i < frameCount; i++) {
        const img = new Image();
        img.src = currentFrame(i);
        images.push(img);
    }

    images[0].onload = () => {
      // Setup initial canvas dimensions based on the first image's aspect ratio
      // to keep it crisp. CSS handles bounding.
      canvas.width = images[0].width;
      canvas.height = images[0].height;
      render();
    };

    function render() {
      if (images[sequence.frame] && context) {
        const img = images[sequence.frame];
        context.clearRect(0, 0, canvas.width, canvas.height);
        context.drawImage(img, 0, 0, canvas.width, canvas.height);
      }
    }

    // Scroll trigger to scrub through frames while inside the hero section
    gsap.to(sequence, {
      frame: frameCount - 1,
      snap: "frame",
      ease: "none",
      scrollTrigger: {
        trigger: "#hero-container",
        start: "top top",
        end: "bottom bottom",
        scrub: 0.5,
        pin: "#hero-image-container", // Pin the image wrapper as they scroll past the space
      },
      onUpdate: () => render() // Explicit arrow function wrapper to avoid losing 'this'
    });
  }
</script>
