---
import { Image } from 'astro:assets';
---

<header class="navbar">
  <div class="container navbar-container">
    <a href="/" class="logo flex items-center gap-8">
      <div class="logo-text">WYNAUT<br/>LABS</div>
      <img src="/images/union.svg" alt="Wynaut Labs" width="55" height="24" />
    </a>
    
    <nav class="nav-links">
      <a href="#how-it-works">How it works</a>
      <a href="#products">Products</a>
      <a href="#pricing">Pricing</a>
      <a href="#team">Team</a>
      <a href="#contact">Contact Us</a>
    </nav>

    <a href="#try" class="btn-primary">
      Try it
      <img src="/images/arrow.svg" alt="" width="7" height="20" />
    </a>
  </div>
</header>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 100;
    padding-top: 11px;
    transition: background 0.3s ease, backdrop-filter 0.3s ease;
  }

  .navbar-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 40px;
  }

  /* When JS adds .scrolled class for a solid bg if needed later */
  .navbar.scrolled .nav-links {
    background: rgba(255, 255, 255, 0.8);
    backdrop-filter: blur(48px);
  }

  .logo {
    text-decoration: none;
    transition: transform 0.3s ease;
  }

  .logo:hover {
    transform: scale(1.05);
  }
  
  .logo-text {
    font-family: var(--font-logo);
    color: var(--c-primary);
    font-weight: 700;
    font-size: 14px;
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .nav-links {
    display: flex;
    gap: 32px;
    background: rgba(255, 255, 255, 0.4);
    backdrop-filter: blur(36px);
    -webkit-backdrop-filter: blur(36px);
    border-radius: 120px;
    padding: 24px 29px;
  }

  .nav-links a {
    color: var(--c-black);
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 17px;
    line-height: 24px;
    text-decoration: none;
    transition: color 0.3s ease, opacity 0.3s ease;
  }

  .nav-links a:hover {
    color: var(--c-primary);
    opacity: 0.8;
  }

  @media (max-width: 1024px) {
    .nav-links {
      display: none; /* simple responsive hide for now */
    }
  }
</style>

<script>
  window.addEventListener('scroll', () => {
    const navbar = document.querySelector('.navbar');
    if (window.scrollY > 50) {
      navbar?.classList.add('scrolled');
    } else {
      navbar?.classList.remove('scrolled');
    }
  });
</script>
