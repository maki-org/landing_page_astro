---

---

<footer id="contact" class="footer-section">
  <div class="container section-container">
    <div class="footer-cta wrapper-border">
      <h2 class="footer-title">Connect with us</h2>
      <p class="footer-subtitle">
        Have questions about Wy or want to bring smarter lecture notes to your
        school? Get in touch with us—we’d love to hear from you.
      </p>

      <a href="mailto:dev@wynautlabs.com" class="btn-primary btn-footer">
        Learn More
        <img
          src="/images/arrow.svg"
          alt=""
          width="7"
          height="20"
          class="btn-arrow"
        />
      </a>
    </div>

    <!-- Small footer copyright inside container -->
    <div class="footer-bottom">
      <p>© 2026 Wynaut Labs. All rights reserved. | <a href="/privacy-policy" class="privacy-link">Privacy Policy</a></p>
    </div>
  </div>
</footer>

<style>
  .footer-section {
    padding: 100px 0 40px;
    background-color: var(--c-white);
  }

  .section-container {
    padding: 0 40px;
    max-width: 1280px;
  }

  .wrapper-border {
    border-top: 0.5px solid var(--c-divider);
    padding: 120px 40px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  /* the Figma gives left/right padding of 300px for desktop to center it narrowly */
  @media (min-width: 1024px) {
    .wrapper-border {
      padding: 120px 300px;
    }
  }

  .footer-title {
    font-size: 60px;
    color: var(--c-black);
    margin-bottom: 32px;
  }

  .footer-subtitle {
    font-size: 15px;
    line-height: 21px;
    color: var(--c-text-muted);
    margin-bottom: 40px;
    max-width: 600px;
  }

  .btn-footer {
    width: 100%;
    max-width: 600px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    border-radius: 1000px;
  }

  .btn-arrow {
    transition: transform 0.3s ease;
  }

  .btn-footer:hover .btn-arrow {
    transform: translateX(4px);
  }

  .footer-bottom {
    margin-top: 40px;
    text-align: center;
    font-size: 14px;
    color: var(--c-text-muted);
  }

  .privacy-link {
    color: var(--c-text-muted);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.2s ease;
  }

  .privacy-link:hover {
    color: var(--c-black);
  }

  @media (max-width: 768px) {
    .footer-title {
      font-size: 48px;
    }
    .wrapper-border {
      padding: 80px 0;
    }
  }
</style>
